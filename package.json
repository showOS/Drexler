{
  "name": "drexler",
  "version": "0.2.34",
  "description": "CLI chat with Drexler, a corporate-executive AI persona built on OpenRouter Gemma 4 31B.",
  "license": "MIT",
  "author": "showOS",
  "homepage": "https://github.com/showOS/Drexler",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/showOS/Drexler.git"
  },
  "bugs": {
    "url": "https://github.com/showOS/Drexler/issues"
  },
  "keywords": [
    "cli",
    "chat",
    "openrouter",
    "gemma",
    "ink",
    "tui",
    "drexler",
    "distressed-debt"
  ],
  "type": "module",
  "bin": {
    "drexler": "src/index.ts"
  },
  "files": [
    "src",
    "prompts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "preferGlobal": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "drexler": "bun run src/index.ts",
    "link": "bun link",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "bunx eslint src tests --max-warnings=0",
    "format": "bunx prettier --write src tests",
    "format:check": "bunx prettier --check src tests",
    "prepublishOnly": "bun test && bun run typecheck && bun run lint && bun run format:check"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "ink": "^7.0.2",
    "marked": "^18.0.3",
    "marked-terminal": "^7.1.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.10.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
